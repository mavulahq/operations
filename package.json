{
  "name": "@mavula/operations",
  "version": "1.0.0",
  "description": "MAVULA Operations - Docker, Kubernetes, Terraform, CI/CD and local platform tooling.",
  "author": "EstandarMustaq <estandarmustaq@mavula.io>",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "guardian:check": "node scripts/guardian.mjs && node --test scripts/check-agent-policy.test.mjs",
    "docker:build": "bash docker/build.sh",
    "docker:push": "bash docker/push.sh",
    "dev:services:up": "docker compose --project-directory ../.. up -d postgres redis",
    "dev:services:down": "docker compose --project-directory ../.. down",
    "dev:services:logs": "docker compose --project-directory ../.. logs -f postgres redis",
    "dev:services:ps": "docker compose --project-directory ../.. ps",
    "k8s:apply": "bash kubernetes/apply.sh",
    "k8s:delete": "bash kubernetes/delete.sh",
    "k3s:deploy": "bash scripts/k3s-deploy.sh",
    "k3s:status": "NAMESPACE=mavula APP_LABEL=workbench bash scripts/health-check.sh",
    "minikube:deploy": "bash scripts/minikube-deploy.sh",
    "minikube:status": "sh -c 'test -n \"$MINIKUBE_PROFILE\" && kubectl --context \"$MINIKUBE_PROFILE\" get pods,services,pvc -n mavula'",
    "minikube:stop": "sh -c 'test -n \"$MINIKUBE_PROFILE\" && minikube stop -p \"$MINIKUBE_PROFILE\"'",
    "minikube:delete": "sh -c 'test -n \"$MINIKUBE_PROFILE\" && minikube delete -p \"$MINIKUBE_PROFILE\"'",
    "tf:init": "terraform -chdir=terraform init",
    "tf:plan": "terraform -chdir=terraform plan",
    "tf:apply": "terraform -chdir=terraform apply",
    "tf:destroy": "terraform -chdir=terraform destroy",
    "deploy:staging": "bash scripts/deploy-staging.sh",
    "deploy:prod": "bash scripts/deploy-production.sh",
    "health:check": "bash scripts/health-check.sh",
    "backup:db": "bash scripts/backup-database.sh",
    "migrate:schema": "bash scripts/migrate-schema.sh"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "dotenv": "^16.3.1"
  },
  "engines": {
    "node": "22.22.3",
    "pnpm": "10.33.0",
    "docker": ">=24.0.0",
    "kubernetes": ">=1.28.0"
  }
}
